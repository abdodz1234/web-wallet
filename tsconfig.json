{
  "compilerOptions": {
    "jsx": "react-jsx",
    "target": "es2020",
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "typeRoots": [
      "node_modules/@types",
      "node_modules/web-ext-types",
      "./src/@types"
    ],
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "types": ["chrome"],
    "baseUrl": "src/",
    "paths": {
      "@app/*": ["app/*"],
      "@core/*": ["app/core/*"],
      "@model/*": ["app/model/*"],
      "@uikit": ["app/uikit"],
      "@uikit/*": ["app/uikit/*"],
      "@pages/*": ["app/pages/*"],
      "@state/*": ["app/state/*"],
      "@assets/*": ["assets/*"]
    }
  },
  "include": ["**/*"],
  "exclude": ["node_modules"]
}
